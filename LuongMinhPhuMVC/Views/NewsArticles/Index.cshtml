@model IEnumerable<BusinessObjects.NewsArticle>

@{
    ViewData["Title"] = "Index";
    var role = Context.Session.GetInt32("ROLE");
}
@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

    <script src="~/js/newsModal.js"></script>
}

@functions {
    bool CanEditOrDelete(BusinessObjects.NewsArticle news)
    {
        var role = Context.Session.GetInt32("ROLE");
        var userId = Context.Session.GetInt32("USERID");

        if (role != 1) return false;

        if (news.CreatedById != userId) return false;

        if (news.NewsStatus == true) return false;

        return true;
    }

}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">News Management</h2>

    @if (role == 1)
    {
        <button class="btn btn-primary px-4"
                onclick="openCreateModal()">
            + Create News
        </button>
    }
</div>

@if (ViewBag.FilteredCategory != null || ViewBag.FilteredTag != null)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-4 rounded-pill px-4">
        <span>
            <i class="bi bi-funnel-fill me-2"></i>
            Showing results for: 
            <strong>
                @(ViewBag.FilteredCategory ?? "")
                @(ViewBag.FilteredTag != null ? (ViewBag.FilteredCategory != null ? " + " : "") + "#" + ViewBag.FilteredTag : "")
            </strong>
        </span>
        <a asp-action="Index" class="btn btn-sm btn-link text-info fw-bold text-decoration-none">Clear Filter</a>
    </div>
}

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-12">
            <div class="card shadow-sm border-0 news-card">
                <div class="card-body">

                    <div class="row align-items-center">

                        <!-- LEFT CONTENT -->
                        <div class="col-lg-8">

                            <h5 class="fw-semibold mb-2">
                                @item.NewsTitle
                            </h5>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl"
                                     width="80"
                                     height="60"
                                     style="object-fit:cover;" />
                            }

                            <div class="mb-2">
                                <span class="badge bg-primary me-2">
                                    @item.Category?.CategoryName
                                </span>

                                @if (item.NewsStatus == true)
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                            </div>

                            <div class="mb-2">
                                @if (item.Tags != null && item.Tags.Any())
                                {
                                    foreach (var tag in item.Tags)
                                    {
                                        <span class="badge bg-light text-dark border me-1">
                                            @tag.TagName
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">No tags</span>
                                }
                            </div>

                            <div class="text-muted small">
                                Created: @item.CreatedDate?.ToString("dd/MM/yyyy")
                                |
                                Author: @item.CreatedBy?.AccountEmail
                            </div>
                        </div>

                        <!-- RIGHT ACTION -->
                        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">

                            <a asp-action="Details"
                               asp-route-id="@item.NewsArticleId"
                               class="btn btn-outline-primary btn-sm me-2">
                                View
                            </a>

                            @if (role == 0 && item.NewsStatus != true)
                            {
                                <a asp-action="Approve"
                                   asp-route-id="@item.NewsArticleId"
                                   class="btn btn-success btn-sm me-2"
                                   onclick="return confirm('Approve this news?')">
                                    Approve
                                </a>
                            }

                            @if (CanEditOrDelete(item))
                            {
                                <button class="btn btn-outline-warning btn-sm me-2"
                                        onclick="openEditModal(
                                                            '@item.NewsArticleId',
                                                            '@item.ImageUrl',
                                                            '@item.NewsTitle',
                                                            '@item.Headline',
                                                            `@item.NewsContent`,
                                                            '@item.NewsSource',
                                                            '@item.CategoryId'
                                                        )">
                                    Edit
                                </button>

                                <a asp-action="Delete"
                                   asp-route-id="@item.NewsArticleId"
                                   class="btn btn-outline-danger btn-sm">
                                    Delete
                                </a>
                            }

                        </div>

                    </div>

                </div>
            </div>
        </div>
    }
</div>


@await Html.PartialAsync("_NewsModal")  
