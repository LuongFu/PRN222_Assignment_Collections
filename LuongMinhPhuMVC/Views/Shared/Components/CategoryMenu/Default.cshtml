@model IEnumerable<BusinessObjects.Category>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var rootCategories = Model.Where(c => c.ParentCategoryId == null).ToList();
    if (!rootCategories.Any() && Model.Any())
    {
        rootCategories = Model.ToList();
    }
    var role = HttpContextAccessor.HttpContext?.Session.GetInt32("ROLE");
}

<li class="nav-item dropdown custom-dropdown">
    <a class="nav-link dropdown-toggle text-black" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-grid-fill me-1"></i> Categories
    </a>
    <ul class="dropdown-menu shadow animate slideIn" aria-labelledby="categoryDropdown">
        @foreach (var category in rootCategories)
        {
            @await Html.PartialAsync("_CategoryMenuItem", new { Category = category, AllCategories = Model })
        }
        
        @if (role == 0 || role == 1)
        {
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item text-primary" asp-controller="Categories" asp-action="Index">
                    <i class="bi bi-gear-fill me-1"></i> Manage Categories
                </a>
            </li>
        }
    </ul>
</li>
