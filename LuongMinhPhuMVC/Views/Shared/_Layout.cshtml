@{
    var role = Context.Session.GetInt32("ROLE");
    var session = Context.Session.GetInt32("USERID");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LuongMinhPhuMVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LuongMinhPhuMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top">
            <div class="container">
                <a class="navbar-brand text-black fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                     LuongMinhPhuMVC
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @if (session != null)
                        {
                            @if (role == 0)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-black" asp-controller="Categories" asp-action="Index">
                                        Category
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-black" asp-controller="Account" asp-action="Index">
                                         Account
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-black" asp-controller="Admin" asp-action="Report">
                                         Report
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-black" asp-controller="NewsArticles" asp-action="Index">
                                         News
                                    </a>
                                </li>
                            }

                            @if (role == 1 || role == 2)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-black" asp-controller="NewsArticles" asp-action="Index">
                                         News
                                    </a>
                                </li>
                                @if (role == 1)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-black" asp-controller="Categories" asp-action="Index">
                                            Category
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-black"
                                           asp-controller="NewsArticles"
                                           asp-action="MyNews">
                                            My News
                                        </a>
                                    </li>
                                }
                                <li class="nav-item">
                                    <a class="nav-link text-black"
                                       asp-controller="Profile"
                                       asp-action="Index">
                                        My Profile
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (session != null)
                        {
                            <li class="nav-item d-flex align-items-center me-3 text-light small">
                                Role: @role
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post">
                                    <button type="submit"
                                            class="btn btn-outline-dark text-black btn-sm rounded-pill px-3">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-dark text-black btn-sm rounded-pill px-3"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Login
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    @* <div class="container">
        <div style="margin-top:90px;"></div>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div> *@
    <div class="container">
        <div class="row">

            @if (session != null)
            {
                <!-- LEFT SIDEBAR -->
                <aside class="col-lg-3 mb-4">
                    <div class="sidebar-box">
                        <h5 class="sidebar-title">Categories</h5>
                        <ul class="list-unstyled sidebar-list">
                            @await Component.InvokeAsync("CategorySidebar")
                        </ul>
                    </div>

                    <div class="sidebar-box mt-4">
                        <h5 class="sidebar-title">Tags</h5>
                        <div class="tag-container">
                            @await Component.InvokeAsync("TagSidebar")
                        </div>
                    </div>
                </aside>

                <!-- MAIN (khi có session) -->
                <main class="col-lg-6 mb-4">
                    @RenderBody()
                </main>

                <!-- RIGHT -->
                <aside class="col-lg-3 mb-4">
                    <div class="sidebar-box">
                        <h5 class="sidebar-title">Random News</h5>
                        @await Component.InvokeAsync("RandomNewsSidebar")
                    </div>
                </aside>
            }
            else
            {
                <!-- MAIN FULL WIDTH KHI CHƯA LOGIN -->
                <main class="col-lg-12 mb-4 d-flex justify-content-center">
                    <div style="max-width:500px; width:100%;">
                        @RenderBody()
                    </div>
                </main>
            }

        </div>
    </div>


    <footer class="bg-black text-light mt-5 py-3">
        <div class="container text-center">
            <small>
                © 2026 LuongMinhPhuMVC |
                <a class="text-decoration-none text-info"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Privacy">
                    Privacy Policy
                </a>
            </small>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
