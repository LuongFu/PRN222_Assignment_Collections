@model IEnumerable<BusinessObjects.Category>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Status</th>
            <th>Parent</th>
            <th>#News</th>
            <th width="180">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.CategoryName</strong></td>

                <td>@item.CategoryDesciption</td>

                <td>
                    @if (item.IsActive == true)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </td>

                <td>
                    @(item.ParentCategory?.CategoryName ?? "Root")
                </td>

                <td>
                    <span class="badge bg-info">
                        @(item.NewsArticles?.Count ?? 0)
                    </span>
                </td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.CategoryId"
                       class="btn btn-warning btn-sm">Edit</a>

                    <a asp-action="Details"
                       asp-route-id="@item.CategoryId"
                       class="btn btn-primary btn-sm">View</a>

                    @if ((item.NewsArticles?.Count ?? 0) == 0)
                    {
                        <a asp-action="Delete"
                           asp-route-id="@item.CategoryId"
                           class="btn btn-danger btn-sm">Delete</a>
                    }
                    else
                    {
                        <button class="btn btn-danger btn-sm" disabled>
                            Delete
                        </button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

