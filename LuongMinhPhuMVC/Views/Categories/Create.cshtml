@model BusinessObjects.Category

@{
    ViewData["Title"] = "Create Category";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden mt-4">
            <div class="card-header bg-primary py-3">
                <h4 class="mb-0 text-white fw-bold text-center">Create New Category</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="CategoryName" class="form-label fw-semibold text-muted small text-uppercase">Category Name</label>
                        <input asp-for="CategoryName" class="form-control rounded-pill px-4 shadow-sm border-light-subtle" placeholder="e.g. Technology News" />
                        <span asp-validation-for="CategoryName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CategoryDesciption" class="form-label fw-semibold text-muted small text-uppercase">Description</label>
                        <textarea asp-for="CategoryDesciption" class="form-control rounded-4 px-4 py-3 shadow-sm border-light-subtle" rows="3" placeholder="Brief description of this category..."></textarea>
                        <span asp-validation-for="CategoryDesciption" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch card p-3 border-light-subtle shadow-sm bg-light flex-row align-items-center flex-wrap">
                            <input name="IsActive" class="form-check-input ms-1 me-3" type="checkbox" value="true" id="isActiveSwitch" checked>
                            <input name="IsActive" type="hidden" value="false">
                            <label class="form-check-label fw-semibold text-dark mb-0" for="isActiveSwitch">Set as Active</label>
                            <p class="text-muted small mb-0 mt-1 ms-4 ps-1 d-block w-100">Inactive categories will be hidden from the public site.</p>
                        </div>
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3">
                             Create Category
                        </button>
                        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none text-center">
                             ← Back to Category List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
